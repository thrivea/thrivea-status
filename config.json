{
  "site": {
    "name": "Thrivea",
    "title": "Thrivea Status",
    "tagline": "Live and historical status of the Thrivea platform.",
    "url": "https://status.thrivea.com",
    "homeUrl": "https://app.thrivea.com",
    "supportEmail": "support@thrivea.com",
    "brandColor": "#7C3AED",
    "historyDays": 90,
    "recentIncidentDays": 15
  },

  "//note": "Multi-environment. Each environment renders its own page (pagePath) and writes its own data (basePath). 'prod' is the public client-facing page at /. 'dev' is an internal page at /dev/, NOT linked from prod. Add qa/aikbank later by appending entries. Health endpoints are anonymous; the azurewebsites.net default host always resolves. DEV REQUIRES that /healthz and /admin/host/ping be publicly reachable (whitelist those paths in Azure access restrictions) — until then dev shows down.",

  "environments": [
    {
      "id": "prod",
      "name": "Thrivea Cloud",
      "label": null,
      "basePath": "api",
      "pagePath": "",
      "groups": [
        { "id": "cloud", "name": "Thrivea Cloud (app.thrivea.com)" }
      ],
      "components": [
        { "id": "api",           "group": "cloud", "name": "Application API",       "description": "Core gRPC/REST API that the Thrivea web app talks to." },
        { "id": "auth",          "group": "cloud", "name": "Authentication & SSO",  "description": "Sign-in, identity, single sign-on and workspace federation." },
        { "id": "networking",    "group": "cloud", "name": "Social Feed",           "description": "Company feed, posts, audience and messaging." },
        { "id": "organization",  "group": "cloud", "name": "HR & Organization",     "description": "Employee records, jobs, compensation and workflows." },
        { "id": "notifications", "group": "cloud", "name": "Notifications & Email", "description": "Email, push and in-app notifications." },
        { "id": "database",      "group": "cloud", "name": "Database",              "description": "Primary PostgreSQL data store." },
        { "id": "background",    "group": "cloud", "name": "Background Jobs",       "description": "Async processing: projections, schedulers, integrations." }
      ],
      "monitors": [
        { "id": "liveness",  "kind": "liveness",    "url": "https://app-thrivea-prod.azurewebsites.net/admin/host/ping", "timeoutMs": 10000, "affects": ["api"] },
        { "id": "readiness", "kind": "health-text", "url": "https://app-thrivea-prod.azurewebsites.net/healthz",          "timeoutMs": 12000, "degradedAboveMs": 4000, "affects": ["api", "auth", "networking", "organization", "notifications", "database"] },
        { "id": "deep",      "kind": "health-json", "url": "https://app-thrivea-prod.azurewebsites.net/healthz/all",      "timeoutMs": 15000, "degradedAboveMs": 6000, "fallbackAffects": ["background"], "checkMap": {
            "postgres-db": "database",
            "init-auth-data-source-pool": "auth",
            "init-networking-data-source-pool": "networking",
            "init-organization-data-source-pool": "organization",
            "init-notification-data-source-pool": "notifications",
            "init-auth-permissions-consolidation": "background",
            "init-networking-auth-policies": "background",
            "init-organization-auth-policies": "background"
        } }
      ]
    },

    {
      "id": "dev",
      "name": "Thrivea — Development",
      "label": "Development",
      "basePath": "api/dev",
      "pagePath": "dev",
      "groups": [
        { "id": "cloud", "name": "Development (app-thrivea-dev)" }
      ],
      "components": [
        { "id": "api",           "group": "cloud", "name": "Application API",       "description": "Core gRPC/REST API on the dev environment." },
        { "id": "auth",          "group": "cloud", "name": "Authentication & SSO",  "description": "Sign-in, identity, single sign-on and workspace federation." },
        { "id": "networking",    "group": "cloud", "name": "Social Feed",           "description": "Company feed, posts, audience and messaging." },
        { "id": "organization",  "group": "cloud", "name": "HR & Organization",     "description": "Employee records, jobs, compensation and workflows." },
        { "id": "notifications", "group": "cloud", "name": "Notifications & Email", "description": "Email, push and in-app notifications." },
        { "id": "database",      "group": "cloud", "name": "Database",              "description": "Primary PostgreSQL data store." },
        { "id": "background",    "group": "cloud", "name": "Background Jobs",       "description": "Async processing: projections, schedulers, integrations." }
      ],
      "monitors": [
        { "id": "liveness",  "kind": "liveness",    "url": "https://app-thrivea-dev.azurewebsites.net/admin/host/ping", "timeoutMs": 10000, "affects": ["api"] },
        { "id": "readiness", "kind": "health-text", "url": "https://app-thrivea-dev.azurewebsites.net/healthz",          "timeoutMs": 12000, "degradedAboveMs": 5000, "affects": ["api", "auth", "networking", "organization", "notifications", "database"] },
        { "id": "deep",      "kind": "health-json", "url": "https://app-thrivea-dev.azurewebsites.net/healthz/all",      "timeoutMs": 15000, "degradedAboveMs": 7000, "fallbackAffects": ["background"], "checkMap": {
            "postgres-db": "database",
            "init-auth-data-source-pool": "auth",
            "init-networking-data-source-pool": "networking",
            "init-organization-data-source-pool": "organization",
            "init-notification-data-source-pool": "notifications",
            "init-auth-permissions-consolidation": "background",
            "init-networking-auth-policies": "background",
            "init-organization-auth-policies": "background"
        } }
      ]
    }
  ],

  "notify": {
    "slackWebhookEnv": "SLACK_WEBHOOK_URL",
    "teamsWebhookEnv": "TEAMS_WEBHOOK_URL"
  }
}
